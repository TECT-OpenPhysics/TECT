# .gitignore for the public TECT mirror.
# Curated by Codes/tools/github_sync_curate.py.

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Python build artefacts (the mirror does not build Python here, but the assets/code/ subtree includes .py files which should be treated as plain text — not compiled).
__pycache__/
*.pyc

# Local environment
.env
.env.*
!.env.example
